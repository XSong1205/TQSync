# TQSync - Telegram QQ Bot Configuration
# 将本文件复制为 .env 并填写实际配置信息

# ===========================================
# Telegram Bot 配置
# ===========================================

# Telegram Bot Token (从 @BotFather 获取)
TELEGRAM_TOKEN=your_bot_token_here

# Telegram 聊天 ID (群组或频道的 ID)
TELEGRAM_CHAT_ID=your_chat_id_here

# ===========================================
# QQ Bot 配置 (NapCat)
# ===========================================

# NapCat WebSocket URL (反向 WebSocket 地址)
NAPCAT_WS_URL=ws://127.0.0.1:8080/ws

# NapCat HTTP API URL (HTTP 接口地址)
NAPCAT_HTTP_URL=http://127.0.0.1:5700

# QQ 群号
QQ_GROUP_ID=your_group_id_here

# ===========================================
# 日志配置
# ===========================================

# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ===========================================
# 可选配置 (通常不需要修改)
# ===========================================

# Telegram 代理设置 (可选)
# TELEGRAM_PROXY={"scheme": "http", "hostname": "127.0.0.1", "port": 7890}
